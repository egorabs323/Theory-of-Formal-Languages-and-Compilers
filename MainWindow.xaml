<Window x:Class="YourNamespace.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Поиск по регулярным выражениям" Height="600" Width="800"
        MinHeight="400" MinWidth="600" Background="#2D2D2D">

    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#4A235A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#9B59B6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6C3483"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="BorderBrush" Value="#9B59B6"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="CodeTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#2C2C2C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="Black"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="AcceptsTab" Value="True"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Visible"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#4A235A" Foreground="White">
            <MenuItem Header="_Файл" Background="#4A235A" Foreground="White">
                <MenuItem Header="_Создать" Click="Create_Click" Background="#6C3483" Foreground="White"/>
                <MenuItem Header="_Открыть" Click="Open_Click" Background="#6C3483" Foreground="White"/>
                <MenuItem Header="_Сохранить" Click="Save_Click" Background="#6C3483" Foreground="White"/>
                <Separator Background="#9B59B6"/>
                <MenuItem Header="_Выход" Click="Exit_Click" Background="#6C3483" Foreground="White"/>
            </MenuItem>
            <MenuItem Header="_Правка" Background="#4A235A" Foreground="White">
                <MenuItem Header="_Отменить" Click="Undo_Click" Background="#6C3483" Foreground="White"/>
                <MenuItem Header="_Повторить" Click="Redo_Click" Background="#6C3483" Foreground="White"/>
                <MenuItem Header="В_ырезать" Click="Cut_Click" Background="#6C3483" Foreground="White"/>
                <MenuItem Header="_Копировать" Click="Copy_Click" Background="#6C3483" Foreground="White"/>
                <MenuItem Header="_Вставить" Click="Paste_Click" Background="#6C3483" Foreground="White"/>
                <Separator Background="#9B59B6"/>
                <MenuItem Header="Выделить _все" Click="SelectAll_Click" Background="#6C3483" Foreground="White"/>
            </MenuItem>
            <MenuItem Header="_Справка" Background="#4A235A" Foreground="White">
                <MenuItem Header="_О программе" Click="About_Click" Background="#6C3483" Foreground="White"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top" Background="#3C3C3C">
            <ToolBar ToolBarTray.IsLocked="True" Background="#3C3C3C">
                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Click="SearchWordsM_Click" 
                        ToolTip="Найти слова, начинающиеся на m или M"
                        Width="120">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="1 " FontSize="14"/>
                        <TextBlock Text="Слова m/M"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Click="SearchEthereum_Click" 
                        ToolTip="Найти Ethereum адреса"
                        Width="120">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="2 " FontSize="14"/>
                        <TextBlock Text="Ethereum"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Click="SearchHTMLTags_Click" 
                        ToolTip="Найти HTML теги с атрибутами"
                        Width="120">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="3 " FontSize="14"/>
                        <TextBlock Text="HTML теги"/>
                    </StackPanel>
                </Button>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="5" Background="#9B59B6"/>

                <Button Style="{StaticResource ToolbarButtonStyle}" 
                        Click="ClearSearch_Click" 
                        ToolTip="Очистить результаты"
                        Width="80">
                    <TextBlock Text="✖ Очистить"/>
                </Button>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom" Background="#3C3C3C" Foreground="White" Height="25">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Grid.Column="0" Padding="10,0,10,0">
                <TextBlock x:Name="StatusCursorPosition" Text="Ln 1, Col 1"/>
            </StatusBarItem>
            <Separator Grid.Column="1" Background="#9B59B6"/>
            <StatusBarItem Grid.Column="2" Padding="10,0,10,0">
                <TextBlock x:Name="SearchCountText" Text="Найдено: 0"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Код для выполнения" Margin="5" Style="{StaticResource GroupBoxStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#3C3C3C" BorderBrush="#9B59B6" BorderThickness="0,0,1,0">
                        <ScrollViewer x:Name="LineNumbersScrollViewer" VerticalScrollBarVisibility="Hidden">
                            <TextBlock x:Name="LineNumbersTextBlock" 
                                       Text="1" 
                                       Padding="5,0,5,0" 
                                       VerticalAlignment="Top"
                                       Foreground="Gray"
                                       FontFamily="Consolas"
                                       FontSize="12"/>
                        </ScrollViewer>
                    </Border>

                    <TextBox x:Name="CodeInputTextBox" 
         Grid.Column="1"
         Style="{StaticResource CodeTextBoxStyle}"
         SelectionChanged="CodeInputTextBox_SelectionChanged"/>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Row="1" Height="5" Background="#9B59B6" 
                          ResizeBehavior="PreviousAndNext" HorizontalAlignment="Stretch"/>

            <GroupBox Grid.Row="2" Header="Результаты поиска" Margin="5" Style="{StaticResource GroupBoxStyle}">
                <DockPanel LastChildFill="True">
                    <Border DockPanel.Dock="Top"
                            Margin="5"
                            Padding="8"
                            Background="#33203A"
                            BorderBrush="#9B59B6"
                            BorderThickness="1">
                        <TextBlock x:Name="SearchModeInfoText"
                                   Foreground="White"
                                   FontFamily="Consolas"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <DataGrid x:Name="SearchResultsGrid"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          IsReadOnly="True"
          SelectionMode="Single"
          Background="#2C2C2C" 
          Foreground="White"
          GridLinesVisibility="Horizontal"
          HorizontalGridLinesBrush="#9B59B6"
          RowBackground="#3C3C3C"
          AlternatingRowBackground="#4A4A4A"
          FontFamily="Consolas" FontSize="12"
          SelectionChanged="SearchResultsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Найдено" Binding="{Binding Match}" Width="300"/>
                        <DataGridTextColumn Header="Позиция" Binding="{Binding Position}" Width="120"/>
                        <DataGridTextColumn Header="Длина" Binding="{Binding Length}" Width="70"/>
                    </DataGrid.Columns>
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#6C3483"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Background" Value="#3C3C3C"/>
                        </Style>
                    </DataGrid.Resources>
                    </DataGrid>
                </DockPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
